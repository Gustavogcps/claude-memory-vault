#!/bin/bash
# managed-by: claude-memory-vault (rendered from templates/vault-post-write.sh.tmpl)
# vault-post-write.sh — PostToolUse(Write|Edit) hook. Reads hook JSON on stdin.
# Exits immediately unless the touched file is inside the internal memory dir; then mirrors.
# NOTE: this runs after EVERY Write/Edit anywhere (hooks cannot pre-filter by path) — the
# early exit below is the filter. The common case (a write that isn't to a memory file) is a
# pure-bash substring reject with no interpreter spawn — ~2ms, essentially the bash-startup floor.
# A python3 parse runs only on the rare write whose JSON even mentions the memory path, to confirm
# it's actually tool_input.file_path.
set -u
MEM_DIR="@@SRC_EXPECTED@@"
HOOKS_DIR="@@HOOKS_DIR@@"

# Fast path: slurp the hook JSON once with a bash builtin (no cat subprocess). If the memory dir
# path is not even a substring, this is definitely not a memory write — exit now, no python3.
IFS= read -r -d '' INPUT 2>/dev/null || true
case "$INPUT" in
  *"$MEM_DIR"*) ;;            # memory path appears somewhere — fall through to the precise check
  *) exit 0 ;;
esac

# Precise check (rare): confirm the memory path is the actual file_path field, not some other
# field that merely contains the string. Only now do we pay for a python3 spawn.
FILE="$(printf '%s' "$INPUT" | /usr/bin/python3 -c 'import json,sys
try:
    print(json.load(sys.stdin).get("tool_input", {}).get("file_path", ""))
except Exception:
    print("")' 2>/dev/null)"

case "$FILE" in
  "$MEM_DIR"/*) exec "$HOOKS_DIR/mirror-memory.sh" sync --quiet ;;
  *) exit 0 ;;
esac
